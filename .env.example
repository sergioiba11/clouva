# CLOUVA Avatar Engine remote assets
# Required for demo mode and for showing the active avatar on /mi-flow/avatar and home.
# Use a public HTTPS URL to a GLB/GLTF humanoid model, optimized for web/mobile.
NEXT_PUBLIC_AVATAR_BASE_URL=

# Optional modular pieces. If empty, their locker categories stay visible but locked as "Próximamente".
NEXT_PUBLIC_AVATAR_HAIR_URL=
NEXT_PUBLIC_AVATAR_TOP_URL=
NEXT_PUBLIC_AVATAR_BOTTOM_URL=
NEXT_PUBLIC_AVATAR_SHOES_URL=

# Temporary demo mode: when true, the engine loads only NEXT_PUBLIC_AVATAR_BASE_URL as one complete humanoid.
NEXT_PUBLIC_AVATAR_DEMO_MODE=true
